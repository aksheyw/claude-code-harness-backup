# .env.example
#
# Commit THIS file. Never commit the real `.env`.
#
# Convention, and the reason it matters: every variable gets a comment saying
# what it is for and exactly where to get it. That sentence is what your AI
# assistant reads back to you when it walks you through setting this up on a
# new machine. Without it, you are left guessing which dashboard issued which
# key six months ago.
#
# Leave secret values BLANK. Placeholder text is fine for things that are not
# secret, like a URL, because it shows the expected shape.

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────

# Project URL. Not a secret.
# Where: your database provider's dashboard, under Project settings then API.
DATABASE_URL=https://your-project-ref.example.com

# Public key, safe to expose in a browser bundle.
# Where: the same page, labelled "anon" or "publishable".
PUBLIC_API_KEY=your-public-key-here

# SECRET. Full admin access, bypasses row-level security.
# Server-side only. Never ship this to a client bundle.
# Where: the same page, labelled "service_role". Treat it like a password.
SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────
# Third-party APIs
# ─────────────────────────────────────────────

# Where: the provider's dashboard, under API keys, then Create new key.
# Scope needed: read-only is enough.
SOME_PROVIDER_API_KEY=

# Used to verify that incoming webhooks really came from the provider.
# Generate your own: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=
